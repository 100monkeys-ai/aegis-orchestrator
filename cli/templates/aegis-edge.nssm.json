{
  "service_name": "AegisEdge",
  "display_name": "AEGIS Edge Daemon",
  "description": "AEGIS Edge Daemon (ADR-117): user-installed daemon enrolled to a tenant.",
  "binary_path": "{{BINARY_PATH}}",
  "args": ["edge", "daemon", "--state-dir", "%USERPROFILE%\\.aegis\\edge"],
  "start_type": "auto",
  "restart_on_failure": true,
  "restart_delay_ms": 5000
}
